body.dark-mode input,
body.dark-mode textarea {
  background-color: #2d3748;
  color: #e0e0e0;
  border-color: #4a5568;
}

body.dark-mode button {
  background-color: #2d3748;
  color: #e0e0e0;
  border-color: #4a5568;
}

body.dark-mode .add-button {
  background-color: #2d8659;
}

body.dark-mode .add-button:hover {
  background-color: #25704d;
}

/* Settings Page Styles */
.settings-page {
  min-height: 100vh;
}

.settings-title {
  font-size: 2rem;
  margin: 20px 0;
  color: #376c58;
}

body.dark-mode .settings-title {
  color: #4299e1;
}

.settings-tile {
  display: flex;
  flex-direction: column;
  gap: 10px;
  cursor: pointer;
}

.tile-icon {
  font-size: 3rem;
}

.tile-label {
  font-size: 1.2rem;
  font-weight: 500;
}

@media (min-width: 1024px) {
  .tile-icon {
    font-size: 4rem;
  }

  .tile-label {
    font-size: 2rem;
  }
}

/* Login Component Styles */
.login-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  padding: 20px;
  background: linear-gradient(135deg, #376c58 0%, #2d5547 100%);
}

body.dark-mode .login-container {
  background: linear-gradient(135deg, #1a202c 0%, #2d3748 100%);
}

.login-card {
  background: white;
  padding: 40px;
  border-radius: 12px;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
  width: 100%;
  max-width: 450px;
}

body.dark-mode .login-card {
  background: #2d3748;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
}

.login-title {
  text-align: center;
  color: #376c58;
  margin-bottom: 10px;
  font-size: 2rem;
}

body.dark-mode .login-title {
  color: #4299e1;
}

.login-subtitle {
  text-align: center;
  color: #666;
  margin-bottom: 30px;
  font-size: 1.3rem;
  font-weight: 400;
}

body.dark-mode .login-subtitle {
  color: #a0aec0;
}

.login-form {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.form-group label {
  font-weight: 500;
  color: #333;
  font-size: 1rem;
}

body.dark-mode .form-group label {
  color: #e0e0e0;
}

.login-input {
  padding: 12px 16px;
  border: 2px solid #ddd;
  border-radius: 8px;
  font-size: 1rem;
  transition: border-color 0.3s;
  background: white;
  color: #333;
}

.login-input:focus {
  outline: none;
  border-color: #376c58;
}

body.dark-mode .login-input {
  background: #1a202c;
  border-color: #4a5568;
  color: #e0e0e0;
}

body.dark-mode .login-input:focus {
  border-color: #4299e1;
}

.login-input:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.login-button {
  padding: 14px;
  background-color: #376c58;
  color: white;
  border: none;
  border-radius: 8px;
  font-size: 1.1rem;
  font-weight: 600;
  cursor: pointer;
  transition: background-color 0.3s;
  margin-top: 10px;
}

.login-button:hover:not(:disabled) {
  background-color: #2d5547;
}

.login-button:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

body.dark-mode .login-button {
  background-color: #4299e1;
}

body.dark-mode .login-button:hover:not(:disabled) {
  background-color: #3182ce;
}

.error-message {
  background-color: #fee;
  color: #c33;
  padding: 12px;
  border-radius: 6px;
  border-left: 4px solid #c33;
  font-size: 0.95rem;
}

body.dark-mode .error-message {
  background-color: #742a2a;
  color: #feb2b2;
  border-left-color: #fc8181;
}

.toggle-auth {
  text-align: center;
  margin-top: 10px;
}

.toggle-button {
  background: none;
  border: none;
  color: #376c58;
  cursor: pointer;
  font-size: 0.95rem;
  text-decoration: underline;
  padding: 5px;
}

.toggle-button:hover:not(:disabled) {
  color: #2d5547;
}

.toggle-button:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

body.dark-mode .toggle-button {
  color: #4299e1;
}

body.dark-mode .toggle-button:hover:not(:disabled) {
  color: #63b3ed;
}

@media (max-width: 480px) {
  .login-card {
    padding: 30px 20px;
  }

  .login-title {
    font-size: 1.5rem;
  }

  .login-subtitle {
    font-size: 1.1rem;
  }
}

/* Sync Component Styles */
.sync-page {
  min-height: 100vh;
}

.sync-title {
  font-size: 2rem;
  margin: 20px 0 10px 0;
  color: #376c58;
}

body.dark-mode .sync-title {
  color: #4299e1;
}

.sync-description {
  font-size: 1rem;
  color: #666;
  margin-bottom: 20px;
  text-align: center;
}

body.dark-mode .sync-description {
  color: #a0aec0;
}

.sync-tile {
  position: relative;
}

.tile-description {
  font-size: 0.9rem;
  font-weight: 400;
  opacity: 0.8;
  margin-top: 5px;
}

.tile-disabled {
  opacity: 0.6;
  cursor: not-allowed !important;
  pointer-events: none;
}

.loading-indicator {
  font-size: 0.85rem;
  color: #376c58;
  margin-top: 10px;
  font-style: italic;
}

body.dark-mode .loading-indicator {
  color: #4299e1;
}

@media (min-width: 1024px) {
  .tile-description {
    font-size: 1.2rem;
  }
}


